# Database
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://[YOUR-PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[YOUR-ANON-KEY]"
SUPABASE_SERVICE_ROLE_KEY="[YOUR-SERVICE-ROLE-KEY]"

# App
NEXT_PUBLIC_APP_DOMAIN="localhost:3000"
APP_DOMAIN="localhost:3000"

# Payments (Mercado Pago - fill later)
MERCADO_PAGO_ACCESS_TOKEN=""
MERCADO_PAGO_WEBHOOK_SECRET=""
# 32+ char secret used to encrypt per-business payment tokens at rest (AES-256-GCM).
# Required in production when PAYMENT_PROVIDER=mercado_pago.
ENCRYPTION_KEY=""

# Rate limiting (Upstash Redis REST) — REQUIRED in production.
# Without these the limiter fails closed in production and blocks rate-limited
# actions (bookings, reviews). Create a free DB at https://upstash.com.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Secret used to authenticate Vercel Cron calls to /api/cron/* (Bearer token).
CRON_SECRET=""

# Comma-separated emails granted platform-admin (/admin) access.
PLATFORM_ADMIN_EMAILS=""

# Payment provider: mock | manual | mercado_pago | webpay
# - mock: simulated payments (dev/test only, NOT for production)
# - manual: admin-confirmed payments from dashboard (NOT for public checkout)
# - mercado_pago / webpay: real online checkout (not yet implemented)
PAYMENT_PROVIDER="mock"

# Override to allow mock in production (UNSAFE - testing only)
# ALLOW_MOCK_PAYMENTS_IN_PRODUCTION="false"

# E2E auth bypass (UNSAFE - testing only)
# When enabled, server-side auth (user.ts) returns a synthetic user for
# requests that include headers x-e2e-auth-secret and x-e2e-test-user-email.
# 
# Security gates:
#   - In dev/test (NODE_ENV !== "production"): secret header optional
#   - In production: requires APP_ENV="e2e" AND E2E_AUTH_BYPASS_SECRET set,
#     and the x-e2e-auth-secret header must match.
#   - Middleware (proxy.ts) only lets the request through; actual auth
#     validation happens server-side so the bypass cannot activate
#     accidentally in production.
# ENABLE_E2E_AUTH_BYPASS="false"
# E2E_AUTH_BYPASS_SECRET="change-me-in-production-e2e"
# APP_ENV="e2e"

# Email (Resend - fill later)
RESEND_API_KEY=""
FROM_EMAIL="hola@agendita.com"

# Web Push (future push notifications - fill later)
WEB_PUSH_VAPID_PUBLIC_KEY=""
WEB_PUSH_VAPID_PRIVATE_KEY=""
WEB_PUSH_CONTACT="mailto:hola@agendita.com"

# Cloudflare R2 (fill later)
R2_ENDPOINT=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""
