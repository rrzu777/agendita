# Integration test database (local Postgres required)
# Copy this to .env.test and fill in your local Postgres URL
# DATABASE_URL will be set to this value for integration tests
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agendita_test

# Required for Prisma (can be same as TEST_DATABASE_URL without pgbouncer)
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/agendita_test

# Payment provider for E2E tests (mock)
PAYMENT_PROVIDER=mock

# App domain for tests
APP_DOMAIN=localhost:3000
NEXT_PUBLIC_APP_DOMAIN=localhost:3000

# Supabase (values from local/test Supabase instance, or placeholders)
NEXT_PUBLIC_SUPABASE_URL=https://test.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=anon-key-for-tests

# NODE_ENV must be test
NODE_ENV=test

# E2E auth bypass — only active when explicitly set to 'true'
# Set to 'true' to allow Playwright tests to skip Supabase auth
ENABLE_E2E_AUTH_BYPASS=true
# NEXT_PUBLIC_ variant required for middleware (Edge runtime in production)
NEXT_PUBLIC_ENABLE_E2E_AUTH_BYPASS=true
